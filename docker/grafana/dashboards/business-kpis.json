{
  "__inputs": [],
  "__requires": [],
  "title": "Business KPIs",
  "uid": "business-kpis",
  "version": 1,
  "panels": [
    {
      "title": "Applications Sent",
      "type": "stat",
      "gridPos": {"h": 6, "w": 4, "x": 0, "y": 0},
      "targets": [{"expr": "increase(application_sent_total[24h])", "legendFormat": "24h"}],
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "title": "Matches Found",
      "type": "stat",
      "gridPos": {"h": 6, "w": 4, "x": 4, "y": 0},
      "targets": [{"expr": "increase(match_found_total[24h])", "legendFormat": "24h"}],
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "title": "Emails Delivered",
      "type": "stat",
      "gridPos": {"h": 6, "w": 4, "x": 8, "y": 0},
      "targets": [{"expr": "increase(application_delivered_total[24h])", "legendFormat": "24h"}],
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "title": "Profiles Created",
      "type": "stat",
      "gridPos": {"h": 6, "w": 4, "x": 12, "y": 0},
      "targets": [{"expr": "increase(profile_created_total[24h])", "legendFormat": "24h"}],
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "title": "Resumes Generated",
      "type": "stat",
      "gridPos": {"h": 6, "w": 4, "x": 16, "y": 0},
      "targets": [{"expr": "increase(resume_generated_total[24h])", "legendFormat": "24h"}],
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "title": "Interviews Scheduled",
      "type": "stat",
      "gridPos": {"h": 6, "w": 4, "x": 20, "y": 0},
      "targets": [{"expr": "increase(interview_scheduled_total[24h])", "legendFormat": "24h"}],
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "title": "Daily Application Trend",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 6},
      "targets": [
        {"expr": "increase(application_sent_total[1d])", "legendFormat": "Sent"},
        {"expr": "increase(application_delivered_total[1d])", "legendFormat": "Delivered"},
        {"expr": "increase(interview_scheduled_total[1d])", "legendFormat": "Interviews"}
      ],
      "datasource": "Prometheus"
    },
    {
      "title": "Delivery Success Rate (7d)",
      "type": "gauge",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 14},
      "targets": [{"expr": "increase(application_delivered_total[7d]) / increase(application_sent_total[7d]) * 100"}],
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": 0},
              {"color": "yellow", "value": 50},
              {"color": "green", "value": 85}
            ]
          }
        }
      }
    },
    {
      "title": "Match Score Distribution",
      "type": "bargauge",
      "gridPos": {"h": 6, "w": 18, "x": 6, "y": 14},
      "targets": [{"expr": "avg(match_score) by (service)", "legendFormat": "{{service}}"}],
      "datasource": "Prometheus"
    }
  ]
}
