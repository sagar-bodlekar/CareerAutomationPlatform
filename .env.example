# ─── PostgreSQL ─────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=career_platform
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/career_platform

# ─── Redis ──────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── MinIO (S3-compatible storage) ─────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_RESUMES_BUCKET=resumes
MINIO_COVER_LETTERS_BUCKET=cover-letters
MINIO_AVATARS_BUCKET=avatars
MINIO_SCRAPING_BUCKET=scraping-artifacts

# ─── Auth (JWT) ─────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-256-bit-secret-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── AI / LLM ──────────────────────────────────────────────
# Ollama (self-hosted local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2:8b

# LocalAI (fallback LLM provider)
LOCALAI_BASE_URL=http://localhost:8080
LOCALAI_DEFAULT_MODEL=llama-3.2-8b-instruct

# ─── Email (SMTP) ──────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@career-platform.local
SMTP_FROM_NAME=Career Platform

# ─── Application ───────────────────────────────────────────
APP_NAME=AI Career Automation Platform
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO

# ─── API Gateway ───────────────────────────────────────────
API_RATE_LIMIT_PER_MINUTE=100
API_BURST_LIMIT=20
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
