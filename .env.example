# ─── PostgreSQL ─────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=career_platform
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/career_platform

# ─── Redis ──────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── MinIO (S3-compatible storage) ─────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_RESUMES_BUCKET=resumes
MINIO_COVER_LETTERS_BUCKET=cover-letters
MINIO_AVATARS_BUCKET=avatars
MINIO_SCRAPING_BUCKET=scraping-artifacts

# ─── Auth (JWT) ─────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-256-bit-secret-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── AI / LLM: Primary (Google Gemini) ────────────────────
# Get your free API key from: https://aistudio.google.com/
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.0-flash
GEMINI_PRO_MODEL=gemini-1.5-pro

# ─── AI / LLM: Fallback (Groq) ────────────────────────────
# Get your free API key from: https://console.groq.com/
GROQ_API_KEY=
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=mixtral-8x7b-32768
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ─── Email (SMTP) ──────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@career-platform.local
SMTP_FROM_NAME=Career Platform

# ─── Application ───────────────────────────────────────────
APP_NAME=AI Career Automation Platform
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO

# ─── API Gateway ───────────────────────────────────────────
API_RATE_LIMIT_PER_MINUTE=100
API_BURST_LIMIT=20
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Monitoring (Phase 10) ────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ─── OpenTelemetry (Tracing) ──────────────────────────────
OTEL_SERVICE_NAME=career-platform
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1
